# ============================================================================
# HunterXJob backend configuration
# Copy this file to `.env` and fill in real values. NEVER commit your real .env.
# ============================================================================

# --- API auth --------------------------------------------------------------
API_KEY=change-me-to-a-long-random-string

# --- Database --------------------------------------------------------------
DATABASE_PATH=./data/hunterxjob.db

# --- LLM provider ----------------------------------------------------------
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini

# --- Automation safety rails ---------------------------------------------
MAX_APPLICATIONS_PER_DAY=15
MIN_DELAY_BETWEEN_APPLICATIONS_SECONDS=90
BLACKLISTED_COMPANIES=
AUTOMATION_ENABLED=true
AUTOMATION_DRY_RUN=true
# Hard environment gate. Runtime/mobile settings cannot override this value.
ALLOW_LIVE_SUBMISSION=false

# --- Job source configuration --------------------------------------------
GREENHOUSE_BOARD_TOKENS=
LEVER_COMPANIES=
GENERIC_FEED_URLS=

# --- SMTP -----------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=

# --- IMAP -----------------------------------------------------------------
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX

# --- Browser runtime ------------------------------------------------------
# Android recommendation: native Termux Chromium exposes CDP on loopback.
# Supported values: cdp, persistent, managed
BROWSER_MODE=cdp
BROWSER_CDP_URL=http://127.0.0.1:9222
BROWSER_EXECUTABLE_PATH=
BROWSER_PROFILE_DIR=./data/browser_profiles/default
BROWSER_ARTIFACT_DIR=./data/artifacts
BROWSER_HEADLESS=true
BROWSER_MAX_APPLICATIONS_PER_SESSION=10
BROWSER_MAX_SESSION_MINUTES=45
BROWSER_CONNECT_TIMEOUT_MS=15000
BROWSER_DEFAULT_TIMEOUT_MS=30000
BROWSER_NAVIGATION_TIMEOUT_MS=45000
BROWSER_HEALTH_TIMEOUT_SECONDS=2.0
PLAYWRIGHT_STORAGE_STATE_DIR=./data/storage_states
RENDERED_DOCS_DIR=./data/rendered

# --- Scheduler intervals -------------------------------------------------
JOB_SEARCH_INTERVAL_MINUTES=60
AUTOMATION_INTERVAL_MINUTES=15
EMAIL_CHECK_INTERVAL_MINUTES=30
REPORT_INTERVAL_MINUTES=1440

LOG_LEVEL=INFO
