# ============================================================================
# HunterXJob backend configuration
# Copy this file to `.env` and fill in real values. NEVER commit your real .env.
# ============================================================================

# --- API auth --------------------------------------------------------------
# Single-user app: every request to /api/* must send header  X-API-Key: <this>
API_KEY=change-me-to-a-long-random-string

# --- Database ----------------------------------------------------------------
# Path to the SQLite database file (created automatically on first run).
DATABASE_PATH=./data/hunterxjob.db

# --- LLM provider ------------------------------------------------------------
# "ollama" (default, local, free, no API key needed) or "openai_compatible"
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI-compatible settings (used when LLM_PROVIDER=openai_compatible)
# Works with OpenAI, Groq, OpenRouter, or any OpenAI-chat-completions-compatible endpoint.
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini

# --- Automation safety rails --------------------------------------------------
MAX_APPLICATIONS_PER_DAY=15
MIN_DELAY_BETWEEN_APPLICATIONS_SECONDS=90
# Comma-separated list of company names/domains to never apply to.
BLACKLISTED_COMPANIES=
# When true, automation runs go through the full pipeline (matching, content
# generation, form-filling) but the adapters stop short of actually submitting.
AUTOMATION_DRY_RUN=true

# --- Job source configuration --------------------------------------------------
# Comma-separated Greenhouse board tokens, e.g. "stripe,airbnb"
GREENHOUSE_BOARD_TOKENS=
# Comma-separated Lever company slugs, e.g. "netflix,figma"
LEVER_COMPANIES=
# Comma-separated generic job-feed URLs (JSON or RSS)
GENERIC_FEED_URLS=

# --- SMTP (outbound application emails) ---------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=

# --- IMAP (inbox monitoring for status updates) --------------------------------
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX

# --- Playwright / browser automation --------------------------------------------
# Directory holding storageState JSON files for opt-in roadmap adapters
# (LinkedIn/Indeed/Upwork). You generate these yourself by logging in once
# interactively in a real browser; HunterXJob never stores your password.
PLAYWRIGHT_STORAGE_STATE_DIR=./data/storage_states
# Path to write resume/cover-letter PDFs to
RENDERED_DOCS_DIR=./data/rendered

# --- Scheduler intervals (minutes) ----------------------------------------------
JOB_SEARCH_INTERVAL_MINUTES=60
AUTOMATION_INTERVAL_MINUTES=15
EMAIL_CHECK_INTERVAL_MINUTES=30
REPORT_INTERVAL_MINUTES=1440

# --- Misc ------------------------------------------------------------------------
LOG_LEVEL=INFO
