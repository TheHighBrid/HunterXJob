<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>{{ resume.name }} - Resume</title>
<style>
  @page { size: Letter; margin: 0.6in; }
  * { box-sizing: border-box; }
  body {
    font-family: Arial, Helvetica, sans-serif;
    color: #1a1a1a;
    font-size: 10.5pt;
    line-height: 1.4;
    margin: 0;
  }
  h1 { font-size: 20pt; margin: 0 0 2px 0; }
  .contact { font-size: 9.5pt; color: #333; margin-bottom: 12px; }
  .contact span:not(:last-child)::after { content: " | "; }
  h2 {
    font-size: 11.5pt;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1.5px solid #333;
    padding-bottom: 2px;
    margin: 14px 0 6px 0;
  }
  .summary { margin-bottom: 8px; }
  .entry { margin-bottom: 8px; }
  .entry-header { display: flex; justify-content: space-between; font-weight: bold; }
  .entry-sub { font-style: italic; color: #333; font-size: 10pt; }
  ul { margin: 4px 0 0 18px; padding: 0; }
  li { margin-bottom: 2px; }
  .skills-list span {
    display: inline-block;
    margin: 0 6px 4px 0;
  }
  .skills-list span:not(:last-child)::after { content: ","; }
</style>
</head>
<body>
  <h1>{{ resume.name }}</h1>
  <div class="contact">
    {% if resume.email %}<span>{{ resume.email }}</span>{% endif %}
    {% if resume.phone %}<span>{{ resume.phone }}</span>{% endif %}
    {% if resume.location %}<span>{{ resume.location }}</span>{% endif %}
    {% if resume.linkedin_url %}<span>{{ resume.linkedin_url }}</span>{% endif %}
    {% if resume.portfolio_url %}<span>{{ resume.portfolio_url }}</span>{% endif %}
  </div>

  {% if resume.summary %}
  <h2>Summary</h2>
  <div class="summary">{{ resume.summary }}</div>
  {% endif %}

  {% if resume.skills %}
  <h2>Skills</h2>
  <div class="skills-list">
    {% for skill in resume.skills %}<span>{{ skill }}</span>{% endfor %}
  </div>
  {% endif %}

  {% if resume.experience %}
  <h2>Experience</h2>
  {% for job in resume.experience %}
  <div class="entry">
    <div class="entry-header">
      <span>{{ job.title }}{% if job.company %} — {{ job.company }}{% endif %}</span>
      <span>{{ job.start_date }} – {{ job.end_date or "Present" }}</span>
    </div>
    {% if job.location %}<div class="entry-sub">{{ job.location }}</div>{% endif %}
    {% if job.bullets %}
    <ul>
      {% for bullet in job.bullets %}<li>{{ bullet }}</li>{% endfor %}
    </ul>
    {% endif %}
  </div>
  {% endfor %}
  {% endif %}

  {% if resume.education %}
  <h2>Education</h2>
  {% for edu in resume.education %}
  <div class="entry">
    <div class="entry-header">
      <span>{{ edu.degree }}{% if edu.school %} — {{ edu.school }}{% endif %}</span>
      <span>{{ edu.end_date }}</span>
    </div>
    {% if edu.details %}<div class="entry-sub">{{ edu.details }}</div>{% endif %}
  </div>
  {% endfor %}
  {% endif %}

  {% if resume.projects %}
  <h2>Projects</h2>
  {% for project in resume.projects %}
  <div class="entry">
    <div class="entry-header"><span>{{ project.name }}</span></div>
    {% if project.description %}<div>{{ project.description }}</div>{% endif %}
  </div>
  {% endfor %}
  {% endif %}
</body>
</html>
