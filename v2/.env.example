HOST=127.0.0.1
PORT=8020
DATABASE_PATH=./data/hunterxjob-v2.db
APPLICATION_MODE=dry_run
AUTOMATION_ENABLED=false
MAX_APPLICATIONS_PER_DAY=5
MIN_MATCH_SCORE=60

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_FAST_MODEL=llama3.2:1b
OLLAMA_QUALITY_MODEL=llama3.2:3b
AI_CONNECT_TIMEOUT=10
AI_GENERATION_TIMEOUT=1200
AI_MAX_RETRIES=2
AI_KEEP_ALIVE=60m

TARGET_LOCATIONS=Ottawa,Gatineau,National Capital Region,Remote Canada,Canada
TARGET_KEYWORDS=fraud,disputes,AML,KYC,compliance,collections,credit,account administration,bilingual,customer operations
EXCLUDED_LOCATIONS=United States,US Remote,Bengaluru,Dublin,Tokyo
EXCLUDED_TITLES=software engineer,legal counsel,product manager
BLACKLISTED_COMPANIES=

GREENHOUSE_BOARD_TOKENS=
LEVER_COMPANIES=
GENERIC_FEED_URLS=

JOB_SEARCH_INTERVAL_MINUTES=60
AUTOMATION_INTERVAL_MINUTES=15
LOG_LEVEL=INFO
