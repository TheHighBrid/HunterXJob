APP_NAME=HunterXJob v2
HOST=127.0.0.1
PORT=8011
DATA_DIR=./data
DATABASE_PATH=./data/hunterxjob-v2.db
LOG_DIR=./logs

APPLICATION_MODE=dry_run
MAX_APPLICATIONS_PER_DAY=5
MINIMUM_MATCH_SCORE=70

AI_PROVIDER=ollama
AI_BASE_URL=http://127.0.0.1:11434
AI_FAST_MODEL=llama3.2:1b
AI_QUALITY_MODEL=llama3.2:3b
AI_CONNECT_TIMEOUT_SECONDS=10
AI_GENERATION_TIMEOUT_SECONDS=1200
AI_MAX_RETRIES=2
AI_KEEP_ALIVE=60m

BROWSER_ENABLED=true
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_SECONDS=120

SCHEDULER_ENABLED=false
JOB_SEARCH_INTERVAL_MINUTES=60
AUTOMATION_INTERVAL_MINUTES=15

TARGET_LOCATIONS=Ottawa,Gatineau,National Capital Region,Remote Canada,Canada
TARGET_KEYWORDS=fraud,disputes,AML,KYC,compliance,collections,credit,bilingual,account administration
EXCLUDED_LOCATIONS=United States,US Remote,Bengaluru,Dublin,Tokyo
EXCLUDED_TITLES=software engineer,legal counsel,product manager
